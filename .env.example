# SplitLLM frontend configuration.
#
# Local dev:  copy this file to `.env` and fill in your values.
#               cp .env.example .env
# Vercel:     set these as Environment Variables in the project settings;
#             vercel_build.sh writes them into a .env at build time.
#
# Note: SUPABASE_ANON_KEY is a publishable/anon key and is public by design
# (security is enforced by Supabase Row-Level Security), so it is safe to expose
# in the client bundle.

# Supabase project URL, e.g. https://xxxxxxxx.supabase.co
SUPABASE_URL=

# Supabase publishable / anon key (starts with sb_publishable_ or is the anon JWT)
SUPABASE_ANON_KEY=

# Backend API base URL (no trailing slash), e.g. https://api.example.com
API_BASE_URL=http://localhost:8081
